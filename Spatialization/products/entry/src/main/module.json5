{
  "module": {
    "name": "spatialzationsample",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "SpatialzationsampleAbility",
    "deviceTypes": [
      "phone",
      "tablet"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "routerMap": "$profile:router_map",
    "abilities": [
      {
        "name": "SpatialzationsampleAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:SpatializationAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:SpatializationAbility_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "ohos.want.action.home"
            ]
          }
        ]
      }
    ],
    "extensionAbilities": [
      {
        "name": "EntryBackupAbility",
        "srcEntry": "./ets/entrybackupability/EntryBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ]
      }
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.DETECT_GESTURE",
        "reason": "$string:gesture_reason",
        "usedScene": {
          "abilities": [
            "SmartreachAbility"
          ],
          "when": "inuse"
        }
      }
    ]
  }
}