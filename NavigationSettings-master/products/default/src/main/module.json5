{
  "module": {
    "name": "multisettingdefaultsample",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "MultiSettingAbility",
    "deviceTypes": [
      "phone",
      "tablet"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "routerMap": "$profile:route_map",
    "abilities": [
      {
        "name": "MultiSettingAbility",
        "srcEntry": "./ets/entryability/MultiSettingDefaultAbility.ets",
        "description": "$string:EntryAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:EntryAbility_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "minWindowWidth": 480,
        "minWindowHeight": 360,
        "orientation": "follow_desktop",
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "ohos.want.action.home"
            ]
          }
        ]
      }
    ],
    "extensionAbilities": [
      {
        "name": "MultisettingBackupAbility",
        "srcEntry": "./ets/entrybackupability/MultisettingDefaultBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ]
      }
    ]
  }
}