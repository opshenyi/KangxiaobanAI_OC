import { HdsNavigation, HdsNavigationTitleMode, HdsTabsController } from '@kit.UIDesignKit';
import { PageContext, PageEnum, StorageKey } from '@ohos/common';
import { HomeListParams } from '@ohos/commonbusiness';

@Component({ freezeWhenInactive: true })
export struct PracticeHomeView {
  @StorageLink((StorageKey.SAMPLE_PAGE_CONTEXT)) samplePageContext: PageContext =
    AppStorage.get<PageContext>(StorageKey.SAMPLE_PAGE_CONTEXT) ?? new PageContext();
  scroller: Scroller = new Scroller();
  homeTabController: HdsTabsController = new HdsTabsController();

  aboutToAppear(): void {
    this.samplePageContext.replacePage({
      routerName: PageEnum.PRACTICES_VIEW,
      param: {
        scroller: this.scroller,
        homeTabController: this.homeTabController,
      } as HomeListParams,
    }, false);
  }

  build() {
    HdsNavigation(this.samplePageContext.navPathStack) {
    }
    .mode(NavigationMode.Stack)
    .hideBackButton(true)
    .hideTitleBar(true)
    .titleMode(HdsNavigationTitleMode.MINI)
    .ignoreLayoutSafeArea([LayoutSafeAreaType.SYSTEM], [LayoutSafeAreaEdge.TOP, LayoutSafeAreaEdge.BOTTOM])
    .width('100%')
    .height('100%')
  }
}